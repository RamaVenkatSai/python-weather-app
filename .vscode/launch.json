{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Flask Weather App",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "FLASK_DEBUG": "1"
      }
    }
  ]
}
